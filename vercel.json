{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/window-tinting-pattaya", "destination": "/window-tinting-chonburi", "permanent": true },
    { "source": "/window-tinting-chiang-rai", "destination": "/locations", "permanent": true },
    { "source": "/window-tinting-samui", "destination": "/locations", "permanent": true },
    { "source": "/window-tinting-krabi", "destination": "/locations", "permanent": true },
    { "source": "/window-tinting-hua-hin", "destination": "/locations", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
